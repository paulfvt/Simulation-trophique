digraph arctique {
    rankdir=LR;

    baleine_a_bosse [label="Baleine à bosse", shape=ellipse, color=green, population=15];
    le_krill [label="Le Krill", shape=ellipse, color=yellow, population=1000];
    petits_poissons [label="Petits Poissons", shape=ellipse, color=green, population=500];
