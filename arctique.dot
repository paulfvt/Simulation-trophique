    manchot_empereur [label="Manchot Empereur", shape=ellipse, color=orange, population=10];
    manchot_adelie [label="Manchot Adélie", shape=ellipse, color=blue, population=150];
    gorfou [label="Gorfou", shape=ellipse, color=blue, population=15];
    leopard_de_mer [label="Léopard de mer", shape=ellipse, color=orange, population=20];
    phoque_de_weddell [label="Phoque de Weddell", shape=ellipse, color=orange, population=100];
    elephant_de_mer [label="Éléphant de mer", shape=ellipse, color=orange, population=80];
    orque [label="Orque", shape=ellipse, color=red, population=5];

    le_krill -> baleine_a_bosse [label="0.9"];
    le_krill -> petits_poissons [label="0.8"];

    petits_poissons -> gorfou [label="0.6"];
    petits_poissons -> gros_poissons [label="0.7"];
