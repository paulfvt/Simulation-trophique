    petits_poissons -> manchot_empereur [label="0.8"];
    petits_poissons -> manchot_adelie [label="0.7"];

    gros_poissons -> manchot_empereur [label="0.1"];
    gros_poissons -> elephant_de_mer [label="0.2"];
    gros_poissons -> leopard_de_mer [label="0.4"];

    gorfou -> leopard_de_mer [label="0.5"];

    manchot_adelie -> leopard_de_mer [label="0.6"];

    manchot_empereur -> orque [label="0.3"];

    phoque_de_weddell -> orque [label="0.4"];

    leopard_de_mer -> orque [label="0.5"];

    elephant_de_mer -> orque [label="0.6"];
}